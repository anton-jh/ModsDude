<UserControl x:Class="ModsDude.Client.Wpf.View.UserControls.DynamicFormEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.UserControls"
             xmlns:vm="clr-namespace:ModsDude.Client.Wpf.ViewModel.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:DynamicFormViewModel, IsDesignTimeCreatable=False}">
    
    <ItemsControl ItemsSource="{Binding Fields}">
        <ItemsControl.ItemTemplate>
            
            <DataTemplate DataType="{x:Type vm:FolderPathDynamicFormFieldViewModel}">
                <StackPanel Orientation="Vertical">
                    <Label Content="{Binding Title}" Margin="0 0 0 12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Pick folder" Command="{Binding PickFolderCommand}" />
                        <TextBox Text="{Binding Value, Mode=TwoWay}" IsReadOnly="True" Width="250" Margin="8 0 0 0" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>
            
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
