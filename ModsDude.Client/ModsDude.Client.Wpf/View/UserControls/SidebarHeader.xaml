<UserControl x:Class="ModsDude.Client.Wpf.View.UserControls.SidebarHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=local:SidebarHeader, IsDesignTimeCreatable=True}">
    
    <Grid ColumnDefinitions="* auto" RowDefinitions="auto auto" Margin="0 32 0 0">

        <TextBlock Grid.Column="0" Grid.Row="0"
                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Margin="16 0 16 4"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Opacity="0.7"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <Button Grid.Column="1" Grid.Row="0"
                Margin="8 0 16 4"
                VerticalAlignment="Center"
                Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Background="Transparent"
                BorderThickness="0"
                Padding="4"
                MinWidth="0"
                MinHeight="0">
            <TextBlock Text="{Binding ActionIcon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <Separator Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                   Foreground="{DynamicResource DividerStrokeColorDefaultBrush}"
                   Margin="4 4" />
        
    </Grid>
    
</UserControl>
