<Page x:Class="ModsDude.Client.Wpf.View.Pages.CreateProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=pvm:DesignTimeCreateProfilePageViewModel, IsDesignTimeCreatable=True}"
      Title="CreateRepoPage">

    <Grid RowDefinitions="*, auto">

        <Border CornerRadius="4 0 0 4" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" Padding="32">
            <StackPanel Orientation="Vertical" >

                <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding RepoName}" />
                <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Foreground="{DynamicResource AccentTextFillColorSecondaryBrush}"
                           Text="Create profile"
                           Margin="0 8 0 36" />

                <Label Content="Name" Margin="0 0 0 12"/>
                <TextBox Width="300" Text="{Binding Path=Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" >
            <Button Content="Save" Command="{Binding Path=SubmitCommand}"
                    Style="{DynamicResource AccentButtonStyle}"
                    Width="250" Margin="32 24" />
        </StackPanel>

    </Grid>
</Page>
