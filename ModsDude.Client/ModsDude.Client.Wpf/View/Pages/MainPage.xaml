<Page x:Class="ModsDude.Client.Wpf.View.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      xmlns:vm="clr-namespace:ModsDude.Client.Wpf.ViewModel.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=pvm:DesignTimeMainPageViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage"
      FontSize="14">

    <Page.Resources>
        <DataTemplate x:Key="SidebarMenuItemTemplate" DataType="{x:Type vm:IMenuItemViewModel}">
            <Grid ClipToBounds="True">
                <TextBlock Text="{Binding Path=Title}"
                           Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           ToolTip="{Binding Path=Title}" ToolTipService.InitialShowDelay="200" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid ColumnDefinitions="200, *">

        <DockPanel Grid.Column="0">
            <ListView DockPanel.Dock="Top"
                      ItemsSource="{Binding Path=MenuItems}"
                      SelectionMode="Single"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      ScrollViewer.CanContentScroll="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemTemplate="{StaticResource SidebarMenuItemTemplate}"
                      >
            </ListView>

            <Separator DockPanel.Dock="Top"
                       BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                       Margin="4 8"
                       />

            <ListView DockPanel.Dock="Top"
                      ItemsSource="{Binding Path=Repos}"
                      SelectionMode="Single"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      ScrollViewer.CanContentScroll="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ItemTemplate="{StaticResource SidebarMenuItemTemplate}"
                      >
            </ListView>
        </DockPanel>

        <Frame Grid.Column="1"
               Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden" />
    </Grid>
</Page>
