<Page x:Class="ModsDude.Client.Wpf.View.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      xmlns:vm="clr-namespace:ModsDude.Client.Wpf.ViewModel.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=pvm:DesignTimeMainPageViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage"
      FontSize="14">

    <Grid ColumnDefinitions="200 *">

        <DockPanel Grid.Column="0">
            
            <ListView DockPanel.Dock="Top"
                      Style="{StaticResource SidebarList}"
                      ItemsSource="{Binding Path=MenuItems}"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      />

            <Separator DockPanel.Dock="Top" Style="{StaticResource SidebarSeparator}" />

            <ListView Style="{StaticResource SidebarList}"
                      ItemsSource="{Binding Path=Repos}"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      />
        </DockPanel>

        <Frame Grid.Column="1"
               Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden" />
    </Grid>
</Page>
