<Page x:Class="ModsDude.Client.Wpf.View.Pages.RepoModsImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      xmlns:vm="clr-namespace:ModsDude.Client.Wpf.ViewModel.ViewModels"
      xmlns:uc="clr-namespace:ModsDude.Client.Wpf.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance pvm:RepoModsImportPageViewModel, IsDesignTimeCreatable=False}"
      Title="RepoModsImportPage">

    <Grid RowDefinitions="*, auto">

        <Border CornerRadius="4 0 0 4" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" Padding="32">
            <StackPanel Orientation="Vertical" >

                <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding RepoName}" />
                <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Foreground="{DynamicResource AccentTextFillColorSecondaryBrush}"
                           Text="Mods | Import"
                           Margin="0 8 0 36" />

                <ListBox
                    ItemsSource="{Binding LocalMods}"
                    Height="500"
                    SelectionMode="Extended">
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Label Content="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" >
            <Button Grid.Column="0" Width="250" Margin="32 24 4 24" Style="{DynamicResource AccentButtonStyle}"
                    Content="Import selected" Command="{Binding ImportCommand}" />
        </StackPanel>

    </Grid>
</Page>
