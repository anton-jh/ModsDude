<Page x:Class="ModsDude.Client.Wpf.View.Pages.ExamplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=pvm:ExamplePageViewModel, IsDesignTimeCreatable=True}"
      Title="ExamplePage"
      FontSize="14">

    <Border Margin="0 0 0 24" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="4 0 0 0" >
        <StackPanel>
            <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
               Text="{Binding Path=Text}" Margin="32" />
        </StackPanel>
    </Border>
</Page>
