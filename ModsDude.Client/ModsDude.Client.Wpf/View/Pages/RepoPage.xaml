<Page x:Class="ModsDude.Client.Wpf.View.Pages.RepoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=pvm:DesignTimeRepoPageViewModel, IsDesignTimeCreatable=True}"
      Title="RepoPage"
      FontSize="14">

    <Grid ColumnDefinitions="200 *">

        <DockPanel Grid.Column="0">

            <ListView DockPanel.Dock="Top"
                      ItemsSource="{Binding Path=MenuItems}" SelectionMode="Single"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      ScrollViewer.CanContentScroll="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Label Content="{Binding Path=Title}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Separator DockPanel.Dock="Top" Style="{StaticResource SidebarSeparator}"/>

            <ListView DockPanel.Dock="Bottom"
                      ItemsSource="{Binding Path=Instances}" SelectionMode="Single"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      ScrollViewer.CanContentScroll="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Label Content="{Binding Path=Title}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Separator DockPanel.Dock="Bottom" Style="{StaticResource SidebarSeparator}"/>

            <ListView ItemsSource="{Binding Path=Profiles}" SelectionMode="Single"
                      SelectedItem="{Binding Path=SelectedMenuItem, Mode=TwoWay}"
                      ScrollViewer.CanContentScroll="False">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Label Content="{Binding Path=Title}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>

        <Frame
            Grid.Column="1"
            Content="{Binding CurrentPage}" NavigationUIVisibility="Hidden" />
    </Grid>
</Page>
