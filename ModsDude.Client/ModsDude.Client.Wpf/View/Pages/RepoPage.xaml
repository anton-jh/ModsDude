<Page x:Class="ModsDude.Client.Wpf.View.Pages.RepoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      xmlns:uc="clr-namespace:ModsDude.Client.Wpf.View.UserControls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=pvm:RepoPageViewModel, IsDesignTimeCreatable=False}"
      Title="RepoPage"
      FontSize="14">

    <Grid ColumnDefinitions="200 *">

        <Grid Grid.Column="0" RowDefinitions="auto auto * auto auto">

            <ListView Grid.Row="0"
                      Style="{StaticResource SidebarList}"
                      ItemsSource="{Binding Path=MenuItems}"
                      SelectedItem="{Binding Path=NavManager.Selected, Mode=TwoWay}" />

            <uc:SidebarHeader Grid.Row="1" Title="Profiles" Command="{Binding LoadProfilesCommand}" ActionIcon="&#xE72C;" />

            <ListView Grid.Row="2"
                      ItemsSource="{Binding Path=Profiles}"
                      Style="{StaticResource SidebarList}"
                      SelectedItem="{Binding Path=NavManager.Selected, Mode=TwoWay}" />

            <uc:SidebarHeader Grid.Row="3" Title="Game instances" Command="" ActionIcon="&#xE72C;" />

            <ListView Grid.Row="4"
                      Style="{StaticResource SidebarList}"
                      ItemsSource="{Binding Path=Instances}"
                      SelectedItem="{Binding Path=NavManager.Selected, Mode=TwoWay}" />
        </Grid>

        <Frame
            Grid.Column="1"
            Content="{Binding NavManager.CurrentPage}" NavigationUIVisibility="Hidden" />
    </Grid>
</Page>
