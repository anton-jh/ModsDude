<Page x:Class="ModsDude.Client.Wpf.View.Pages.CreateRepoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=pvm:CreateRepoPageViewModel, IsDesignTimeCreatable=False}"
      Title="CreateRepoPage">

    <Grid RowDefinitions="*, auto">

        <Border CornerRadius="4 0 0 4" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" Padding="32">
            <StackPanel Orientation="Vertical" >

                <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="ModsDude" />
                <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Foreground="{DynamicResource AccentTextFillColorSecondaryBrush}"
                           Text="Create repo"
                           Margin="0 8 0 36" />

                <Label Content="Name" Margin="0 0 0 12"/>
                <TextBox Width="300" Text="{Binding Path=Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />

                <Label Margin="0 16 0 12" Content="Adapter" />

                <ComboBox Width="300" HorizontalAlignment="Left"
                          ItemsSource="{Binding Path=AvailableGameAdapters}"
                          SelectedValue="{Binding Path=SelectedGameAdapter}"
                          >
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Path=DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Frame Content="{Binding AdapterConfigurationModel}" NavigationUIVisibility="Hidden" />

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" >
            <Button Content="Save" Command="{Binding Path=SubmitCommand}"
                    Style="{DynamicResource AccentButtonStyle}"
                    Width="250" Margin="32 24" />
        </StackPanel>

    </Grid>
</Page>
