<Page x:Class="ModsDude.Client.Wpf.View.Pages.ProfileModsEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfileModsEditorPage"
      d:DataContext="{d:DesignInstance Type=pvm:ProfileModsEditorPageViewModel}">

    <Grid RowDefinitions="*, auto">

        <Border CornerRadius="4 0 0 4" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" Padding="32">
            <StackPanel Orientation="Vertical" >

                <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding Name}" />
                <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Foreground="{DynamicResource AccentTextFillColorSecondaryBrush}"
                           Text="Mods"
                           Margin="0 8 0 36" />

                <Grid ColumnDefinitions="* 50 *">

                    <ListView ItemsSource="{Binding Items}">
                        
                    </ListView>

                </Grid>

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" >
            <Button Grid.Column="0" Width="250" Margin="32 24 4 24" Style="{DynamicResource AccentButtonStyle}"
                    Content="Save changes" Command="{Binding SaveChangesCommand}" />
        </StackPanel>

    </Grid>

</Page>
