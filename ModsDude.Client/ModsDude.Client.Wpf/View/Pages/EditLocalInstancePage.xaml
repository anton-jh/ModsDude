<Page x:Class="ModsDude.Client.Wpf.View.Pages.EditLocalInstancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ModsDude.Client.Wpf.View.Pages"
      xmlns:pvm="clr-namespace:ModsDude.Client.Wpf.ViewModel.Pages"
      xmlns:uc="clr-namespace:ModsDude.Client.Wpf.View.UserControls"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      d:DataContext="{d:DesignInstance pvm:EditLocalInstancePageViewModel, IsDesignTimeCreatable=False}"
      Title="EditLocalInstancePage">

    <Grid RowDefinitions="*, auto">

        <Border CornerRadius="4 0 0 4" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" Padding="32">
            <StackPanel Orientation="Vertical">

                <TextBlock Style="{DynamicResource TitleTextBlockStyle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding OriginalName}" />
                <TextBlock Style="{DynamicResource SubtitleTextBlockStyle}" Foreground="{DynamicResource AccentTextFillColorSecondaryBrush}"
                           Text="Admin"
                           Margin="0 8 0 36" />

                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="16">
                    <GroupBox Header="Basics" Padding="0 16 0 16">
                        <StackPanel Orientation="Vertical">
                            <Label Content="Name" Margin="0 0 0 12"/>
                            <TextBox Width="300" Text="{Binding Path=Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </GroupBox>
                </Border>

                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="16"
                        Margin="0 16 0 0">
                    <GroupBox Header="Game adapter settings" Padding="0 16 0 16">
                        <uc:DynamicFormEditor DataContext="{Binding InstanceSettings}" />
                    </GroupBox>
                </Border>

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" >
            <Button Grid.Column="0" Width="250" Margin="32 24 4 24" Style="{DynamicResource AccentButtonStyle}"
                    Content="Save changes" Command="{Binding Path=SaveChangesCommand}" />

            <Button Grid.Column="2" Width="250" Margin="4 24 32 24"
                    Content="Delete repo" Command="{Binding Path=DeleteRepoCommand}" />
        </StackPanel>

    </Grid>
</Page>
